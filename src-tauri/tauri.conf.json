{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arboretum",
  "version": "0.1.0",
  "identifier": "com.research.newsletter",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Arboretum",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Arboretum",
    "shortDescription": "AI-curated research digests",
    "longDescription": "Arboretum generates curated research digests from OpenAlex and arXiv using AI. Features include multi-topic generation, competition scanning, email delivery, and scheduled runs via each OS's native scheduler (Windows Task Scheduler, macOS launchd).",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "startMenuFolder": "Arboretum"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    }
  }
}
